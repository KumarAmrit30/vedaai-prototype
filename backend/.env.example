# Server
PORT=8000

# Database
MONGODB_URI=mongodb://localhost:27017/vedaai

# Redis (production: Upstash rediss://...)
REDIS_URL=redis://localhost:6379

# Local fallback when REDIS_URL is not set:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# AI provider: groq (default) | gemini
AI_PROVIDER=groq

# Groq (required when AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (required when AI_PROVIDER=gemini)
# GEMINI_API_KEY=your_gemini_api_key

# Frontend origin for CORS + Socket.IO (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000
