# Server
PORT=8000

# Database
MONGODB_URI=mongodb://localhost:27017/vedaai

# Redis (production: Upstash rediss://...)
REDIS_URL=redis://localhost:6379

# Local fallback when REDIS_URL is not set:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# AI provider: gemini (default) | groq
AI_PROVIDER=gemini

# Gemini (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key

# Groq (required when AI_PROVIDER=groq)
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile

# Frontend origin for CORS + Socket.IO (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000

# Firebase Auth (optional — set AUTH_ENABLED=true to require Bearer tokens on /api/assignments)
AUTH_ENABLED=false
# FIREBASE_PROJECT_ID=your_firebase_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
