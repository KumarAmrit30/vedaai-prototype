# AI provider: groq (default) | gemini | vertex
AI_PROVIDER=groq

# Vertex AI (required when AI_PROVIDER=vertex)
# Local: use ADC via `gcloud auth application-default login`
# Render: set GOOGLE_APPLICATION_CREDENTIALS to examforge-vertex SA JSON
# GCP_PROJECT_ID=aarogya-vault-dev
# VERTEX_LOCATION=asia-south1
# VERTEX_MODEL=gemini-2.5-flash
# VERTEX_MAX_OUTPUT_TOKENS=8192
# VERTEX_TOP_P=0.95
# VERTEX_SECTION_DELAY_MS=0
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/examforge-vertex-key.json

# Gemini AI Studio (required when AI_PROVIDER=gemini)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash

# Groq (required when AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
